Modified version of https://github.com/DiscordMessenger/dm/blob/master/doc/pentium-toolchain/gcc.diff
Removes the use of some APIs only present in newer Windows versions from libgcc.

--- a/libgcc/config/i386/gthr-win32.h
+++ b/libgcc/config/i386/gthr-win32.h
@@ -627,7 +627,7 @@
 __GTHREAD_WIN32_INLINE int
 __gthread_equal (__gthread_t __t1, __gthread_t __t2)
 {
-  return GetThreadId ((HANDLE) __t1) == GetThreadId ((HANDLE) __t2);
+  return __t1 == __t2; //GetThreadId ((HANDLE) __t1) == GetThreadId ((HANDLE) __t2);
 }
 
 __GTHREAD_WIN32_INLINE int
@@ -746,6 +746,7 @@
 __GTHREAD_WIN32_INLINE int
 __gthread_mutex_trylock (__gthread_mutex_t *__mutex)
 {
+/*
   if (__GTHREAD_WIN32_ACTIVE_P ())
     {
       BOOL __ret = TryEnterCriticalSection ((LPCRITICAL_SECTION) __mutex);
@@ -764,6 +765,9 @@
     }
   else
     return 0;
+*/
+	// TODO
+	return 0;
 }
 
 __GTHREAD_WIN32_INLINE int
@@ -777,10 +781,14 @@
 __GTHREAD_WIN32_INLINE int
 __gthread_recursive_mutex_trylock (__gthread_recursive_mutex_t *__mutex)
 {
+/*
   if (__GTHREAD_WIN32_ACTIVE_P ())
     return TryEnterCriticalSection ((LPCRITICAL_SECTION) __mutex) ? 0 : 1;
   else
     return 0;
+*/
+	// TODO
+	return 0;
 }
 
 #if __GTHREAD_HAS_COND
--- a/libstdc++-v3/src/c++20/tzdb.cc
+++ b/libstdc++-v3/src/c++20/tzdb.cc
@@ -1775,6 +1775,19 @@ namespace std::chrono
     string_view
     detect_windows_zone() noexcept
     {
+#if defined(_WIN32_WINNT) && _WIN32_WINNT < 0x0600
+      static const HMODULE kernel32 = LoadLibraryW(L"kernel32.dll");
+      using GetDynamicTimeZoneInformation_t =
+        DWORD (WINAPI *) (PDYNAMIC_TIME_ZONE_INFORMATION);
+      auto *GetDynamicTimeZoneInformation =
+        reinterpret_cast<GetDynamicTimeZoneInformation_t>(
+          GetProcAddress(kernel32, "GetDynamicTimeZoneInformation"));
+      // MSVC's implementation dynamically loads `icu.dll`. It won't
+      // work until Windows 10 v1903. So we simply "fail as expected".
+      if (!GetDynamicTimeZoneInformation)
+        return {};
+#endif
+
       DYNAMIC_TIME_ZONE_INFORMATION information{};
       if (GetDynamicTimeZoneInformation(&information) == TIME_ZONE_ID_INVALID)
 	return {};
